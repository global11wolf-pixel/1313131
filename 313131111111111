-- Tab switching system
local function SwitchTab(tabName)
    -- Hide all content frames
    the_left_tab.Visible = false
    the_middle_tab.Visible = false
    the_right_tab.Visible = false
    
    -- Reset all tab colors
    for _, tab in pairs(Name_tab:GetChildren()) do
        if tab:IsA("Frame") then
            tab.BackgroundColor3 = Color3.fromRGB(65, 65, 63)
        end
    end
    
    -- Show selected tab content
    if tabName == "aimbot" then
        the_left_tab.Visible = true
        tab_aim.BackgroundColor3 = Color3.fromRGB(85, 85, 83)
    elseif tabName == "visuals" then
        the_middle_tab.Visible = true
        tab_visuals.BackgroundColor3 = Color3.fromRGB(85, 85, 83)
    elseif tabName == "misc" then
        the_right_tab.Visible = true
        tab_misc.BackgroundColor3 = Color3.fromRGB(85, 85, 83)
    end
end

