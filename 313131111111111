function Library:Notify(text, duration)
    duration = duration or 3
    
    local notif = notification_name:Clone()
    notif.TextLabel_3.Text = text
    notif.Position = UDim2.new(1.2, 0, 0.837, 0)
    notif.Parent = ScreenGui
    
    -- Slide in
    TweenService:Create(notif, TweenInfo.new(0.3), {
        Position = UDim2.new(0.813, 0, 0.837, 0)
    }):Play()
    
    -- Wait and slide out
    wait(duration)
    TweenService:Create(notif, TweenInfo.new(0.3), {
        Position = UDim2.new(1.2, 0, 0.837, 0)
    }):Play()
    
    wait(0.3)
    notif:Destroy()
end

